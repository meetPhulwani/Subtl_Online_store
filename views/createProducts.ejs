<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SUBTL | Add Product</title>
    <style>
*{
    font-family: Arial, Helvetica, sans-serif;
}
.layout {
    display: flex;
    min-height: 100vh;
}
body{
    background:linear-gradient(to right,white,rgb(199,255,193));
    height: 600px;
}

.flash-box {
    opacity: 1;
    transition: opacity 1s ease-in-out;
}
.flash-box.hide {
    opacity: 0;
}

.sidebar {
    width: 22%;
    padding: 20px;
    border-right: 1px solid #52b788;
}

.sidebar a {
    display: block;
    margin-bottom: 10px;
    color: black;
    text-decoration: none;
    font-size: 16px;
    position: relative;
    top: 100px;
}

.main {
    flex: 1;
    padding: 40px;
}

.main h2 {
    font-size: 24px;
    margin-bottom: 20px;
}

.section h3 {
    margin-bottom: 10px;
    font-size: 18px;
    font-weight: bold;
}

.grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}
input{
    width: 40px;
}

.input,
.input-file {
    padding: 10px;
    width: 90%;
    border: 1px solid #ccc;
    border-radius: 6px;
    margin-bottom: 10px;
    font-size: 15px;
    margin-top: 5px;
}

.btn {
    background: #52b788;
    color: white;
    padding: 12px 18px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    margin-top: 20px;
    font-size: 16px;
}

.btn:hover {
    background: #52b78800;
    border: #52b788 solid 3px;
    color: #52b788;
}

#logo{
    height: 110px;
    position: absolute;
}
    </style>
</head>
<body>

    <% if (success && success.length > 0) { %>
    <div class="flash-box" style="
        position:absolute;top:20px;left:50%;
        transform:translateX(-50%);
        background-color:#52b788;padding:12px 25px;
        border-radius:8px;color:white;font-size:18px;
        box-shadow:0 0 10px rgba(0,0,0,0.2);z-index:2000;">
        <%= success[0] %>
    </div>
    <% } %>

    <% if (error && error.length > 0) { %>
    <div class="flash-box" style="
        position:absolute;top:20px;left:50%;
        transform:translateX(-50%);
        background-color:#ff4d4d;padding:12px 25px;
        border-radius:8px;color:white;font-size:18px;
        box-shadow:0 0 10px rgba(0,0,0,0.2);z-index:2000;">
        <%= error[0] %>
    </div>
    <% } %>

    <img src="/subtl_black.png" id="logo" alt="">


<div class="layout">

    <aside class="sidebar">
        <nav>
            <a href="">All Products</a>
            <a href="">Create New Product</a>
        </nav>
    </aside>

    <main class="main">
        <h2>Create New Product</h2>

        <form autocomplete="off" action="/products/create" method="post" enctype="multipart/form-data">

            <div class="section">
                <h3>Product Details</h3>

                <label>Product Image</label>
                <input name="image" type="file" class="input-file">

                <div class="grid">
                    <input name="name" type="text" placeholder="Product Name" class="input">
                    <input name="price" type="text" placeholder="Product Price" class="input">
                    <input name="discount" type="text" placeholder="Discount Price" class="input">
                </div>
            </div>

            <div class="section">
                <h3>Panel Details</h3>

                <div class="grid">
                    <input name="bgcolor" type="text" placeholder="Background Color" class="input">
                    <input name="panelcolor" type="text" placeholder="Panel Color" class="input">
                    <input name="textcolor" type="text" placeholder="Text Color" class="input">
                </div>
            </div>

            <button type="submit" class="btn">Create New Product</button>
        </form>
    </main>

</div>


<script>
    setTimeout(() => {
        const flash = document.querySelector('.flash-box');
        if (flash) {
            flash.classList.add('hide');
        }
    }, 5000);
</script>

</body>
</html>
