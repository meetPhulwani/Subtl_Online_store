<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reset Password</title>
    <style>
        body{
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
            background:#f1f1f1;
            font-family:Arial;
        }
        .box{
            background:white;
            padding:30px;
            border-radius:10px;
            box-shadow:0 0 10px rgba(0,0,0,0.2);
            width:350px;
        }
        input,button{
            width:100%;
            height:40px;
            margin-top:15px;
        }
        button{
            background:#52b788;
            border:none;
            color:white;
            cursor:pointer;
            font-size:16px;
        }
    </style>
</head>
<body>

<div class="box">
    <h2>Reset Password</h2>

    <form action="/users/reset-password/<%= token %>" method="POST">
        <input type="password" name="password" placeholder="New password" required>
        <button type="submit">Reset Password</button>
    </form>
</div>

</body>
</html>
